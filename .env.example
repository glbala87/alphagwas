# AlphaGWAS Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ============================================
# Required for API/auth
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=

# ============================================
# External API tokens
# ============================================
# LDlink API token - get from https://ldlink.nih.gov/?tab=apiaccess
LDLINK_TOKEN=

# AlphaGenome API key (if using hosted API)
ALPHAGENOME_API_KEY=

# ============================================
# API configuration
# ============================================
# Comma-separated allowed CORS origins
ALPHAGWAS_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# API bind address (use 127.0.0.1 for local, 0.0.0.0 for container)
ALPHAGWAS_API_HOST=127.0.0.1
ALPHAGWAS_API_PORT=8000

# Maximum upload file size in bytes (default: 100MB)
ALPHAGWAS_MAX_UPLOAD_BYTES=104857600

# Maximum jobs stored
ALPHAGWAS_MAX_JOBS=1000

# Rate limiting (slowapi format: "requests/period")
ALPHAGWAS_RATE_LIMIT=30/minute
ALPHAGWAS_RATE_LIMIT_SUBMIT=5/minute

# ============================================
# Database (for pipeline results)
# ============================================
# SQLite (local): sqlite:///alphagwas.db
# PostgreSQL:     postgresql://user:password@host:5432/alphagwas
DATABASE_URL=sqlite:///alphagwas.db

# Job storage database (defaults to DATABASE_URL if not set)
# ALPHAGWAS_JOB_DB_URL=sqlite:///alphagwas_jobs.db

# ============================================
# Celery / Redis (for job queue)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
